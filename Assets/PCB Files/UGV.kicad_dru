(version 1)
(rule Minimum_annular_width_1
	(constraint annular_width (min 0.2mm))
)
(rule Hole_to_hole_distance_1
	(constraint hole_to_hole (min 0.4mm))
)
(rule Minimum_text_height_and_thickness_1
	(constraint text_height (min 0.7mm))
	(constraint text_thickness (min 0.16mm))
)
(rule Silk_to_soldermask_clearance_1
	(constraint silk_clearance (min 0.2mm))
	(condition "L == 'F.Mask' || L == 'B.Mask'")
)
